  <property name="styleSheet">
   <string notr="true">/* ==========================================================================
   MENÚ PRINCIPAL / QMENUBAR
   ========================================================================== */

QMenuBar {
    background-color: #181818;
    color: #E8D9A8;
    border-bottom: 1px solid #6E5A1E;
    spacing: 5px;
}

QMenuBar::item {
    background: transparent;
    padding: 6px 15px;
    margin: 2px;
    border-radius: 4px;
}

QMenuBar::item:selected {
    background-color: #2A2A2A;
    color: #F5D76E;
}

QMenuBar::item:pressed {
    background-color: #D4AF37;
    color: #121212;
}

/* ==========================================================================
   MENÚ DESPLEGABLE / QMENU
   ========================================================================== */

QMenu {
    background-color: #1B1B1B;
    color: #E8D9A8;
    border: 1px solid #6E5A1E;
    padding: 5px;
}

QMenu::item {
    padding: 8px 30px 8px 25px;
    border-radius: 4px;
    background-color: transparent;
}

QMenu::item:selected {
    background-color: #D4AF37;
    color: #121212;
}

QMenu::item:disabled {
    color: #666666;
}

QMenu::separator {
    height: 1px;
    background: #6E5A1E;
    margin: 5px 10px;
}

/* ==========================================================================
   ICONOS Y CHECKS
   ========================================================================== */

QMenu::indicator {
    width: 16px;
    height: 16px;
}

QMenu::indicator:checked {
    background-color: #D4AF37;
    border: 1px solid #F5D76E;
    border-radius: 3px;
}

QMenu::right-arrow {
    width: 10px;
    height: 10px;
}</string>
