  <property name="styleSheet">
   <string notr="true">/* --- Ventana principal --- */
QDialog {
    background-color: #0d0d0d;   /* negro profundo */
    color: #FFD700;              /* dorado */
    font-family: &quot;Segoe UI&quot;, Arial, sans-serif;
    font-size: 14px;
    border: 2px solid #FFD700;
    border-radius: 8px;
}

/* --- Etiquetas --- */
QLabel {
    color: #FFD700;
    font-size: 13px;
    font-weight: bold;
}

/* --- Campos de entrada --- */
QLineEdit {
    background-color: #1a1a1a;
    color: #ffffff;
    border: 1px solid #FFD700;
    border-radius: 6px;
    padding: 6px;
}

QLineEdit:focus {
    border: 1px solid #FFA500;   /* dorado más intenso al enfocarse */
    background-color: #262626;
}

/* --- Botones --- */
QPushButton {
    background-color: #FFD700;   /* dorado */
    color: #000000;              /* texto negro */
    border-radius: 6px;
    padding: 8px 14px;
    font-weight: bold;
    transition: all 0.3s ease;
}

QPushButton:hover {
    background-color: #FFC107;   /* dorado más oscuro */
    color: #0d0d0d;
}

QPushButton:pressed {
    background-color: #FFA500;   /* naranja/dorado intenso */
    color: #ffffff;
}

/* --- Resultado --- */
#lbl_resultado {
    color: #FFD700;
    font-size: 14px;
    font-weight: bold;
    background-color: #1a1a1a;
    border: 1px solid #FFD700;
    border-radius: 6px;
    padding: 6px;
}
</string>
