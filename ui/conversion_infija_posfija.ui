  <property name="styleSheet">
   <string notr="true">/* ================================================
   HOJA DE ESTILO COMPLETA: MODO OSCURO CORPORATIVO
   ================================================ */

/* --- FONDO PRINCIPAL DE LA VENTANA --- */
QWidget {
    background-color: #111827; /* Negro Premium/Gris muy oscuro */
    color: #F3F4F6; /* Texto general en gris claro para alta legibilidad */
    font-family: &quot;Segoe UI&quot;, &quot;Arial&quot;, sans-serif;
    font-size: 13px;
}

/* --- ESTILO PARA ENTRADAS DE TEXTO (QLineEdit) --- */
QLineEdit {
    background-color: #1F2937; /* Un gris un poco más claro que el fondo */
    border: 1px solid #374151; /* Borde sutil */
    border-radius: 6px;
    padding: 8px 12px;
    color: #FFFFFF; /* Texto blanco puro al escribir */
    selection-background-color: #4B5563;
}

QLineEdit:focus {
    border: 2px solid #9CA3AF; /* Borde gris claro brillante al enfocar */
    background-color: #1F2937;
}

QLineEdit:disabled {
    background-color: #111827;
    color: #4B5563;
    border: 1px solid #1F2937;
}

/* --- ESTILO PARA BOTONES (QPushButton) --- */
QPushButton {
    background-color: #374151; /* Botón gris grafito oscuro */
    color: #FFFFFF;
    font-weight: bold;
    border: 1px solid #4B5563; /* Borde que le da tridimensionalidad */
    border-radius: 6px;
    padding: 10px 20px;
}

QPushButton:hover {
    background-color: #4B5563; /* Se aclara ligeramente al pasar el mouse */
}

QPushButton:pressed {
    background-color: #1F2937; /* Se oscurece al hacer clic */
    border: 1px solid #374151;
}

QPushButton:disabled {
    background-color: #111827;
    color: #4B5563;
    border: 1px solid #1F2937;
}

/* --- ESTILO PARA ETIQUETAS / TEXTOS (QLabel) --- */
QLabel {
    background-color: transparent; /* Evita que la etiqueta tape el fondo */
    color: #E5E7EB; /* Gris claro suave para no cansar la vista */
}

/* Clase opcional para títulos destacados (asigna este objectName en Qt Designer) */
QLabel#tituloPrincipal {
    font-size: 18px;
    font-weight: bold;
    color: #FFFFFF; /* Blanco puro para el título */
}</string>
